{
  "name": "open-book",
  "version": "0.0.0-semantically-released",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "packages/ui",
    "packages/app",
    "packages/web"
  ],
  "scripts": {
    "build": "npm --workspace @open-book/ui run build && npm --workspace @open-book/app run tauri build",
    "commitlint": "commitlint --edit",
    "dev": "concurrently --kill-others \"npm:watch-app\" \"npm:watch-web\" \"npm:watch-ui\" \"npm:watch-ui-css\" \"npm:watch-ui-types\"",
    "lint": "npm --workspaces run lint",
    "lint-fix": "npm --workspaces run lint-fix",
    "setup": "tsx scripts/setup-environment.ts",
    "tauri": "npm --workspace @open-book/app run tauri",
    "test": "echo \"Warning: no test specified\" && exit 0",
    "prepare": "husky",
    "watch-app": "npm --workspace @open-book/app run tauri dev",
    "watch-ui": "npm --workspace @open-book/ui run dev",
    "watch-ui-css": "npm --workspace @open-book/ui run dev-css",
    "watch-ui-types": "npm --workspace @open-book/ui run dev-types",
    "watch-web": "npm --workspace @open-book/web run dev",
    "postversion": "npm version --workspaces $(npm pkg get version | sed 's/\"//g')"
  },
  "author": "Eliot Lim",
  "license": "MIT",
  "dependencies": {
    "@open-book/ui": "*",
    "resolve-tspaths": "^0.8.22",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@tauri-apps/cli": "^1.6.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "concurrently": "^9.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.6",
    "rollup": "^4.22.4",
    "rollup-plugin-dts": "^6.1.1",
    "semantic-release": "^24.1.1",
    "tslib": "^2.7.0",
    "tsx": "^4.19.1"
  }
}
