{
  "name": "open-book",
  "version": "0.0.0-workspace",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "scripts": {
    "build": "pnpm run build:libs && pnpm run build:web && pnpm run build:desktop",
    "build:libs": "pnpm --filter @book.dev/sdk run build && pnpm --filter @book.dev/ui run build && pnpm --filter @book.dev/server run build",
    "build:web": "pnpm --filter @book.dev/web run build",
    "build:desktop": "pnpm --filter @book.dev/app run tauri build",
    "build:sidecar": "pnpm --filter @book.dev/server run build:sidecar",
    "commitlint": "commitlint --edit",
    "dev:prepare": "pnpm --filter @book.dev/sdk run build && pnpm --filter @book.dev/ui run build",
    "dev": "pnpm run dev:prepare && concurrently --kill-others \"pnpm:watch-sdk\" \"pnpm:watch-server\" \"pnpm:watch-app\" \"pnpm:watch-web\" \"pnpm:watch-ui\" \"pnpm:watch-ui-css\" \"pnpm:watch-ui-types\"",
    "lint": "pnpm -r run lint",
    "lint-fix": "pnpm -r run lint-fix",
    "typecheck": "pnpm -r --if-present run typecheck",
    "tauri": "pnpm --filter @book.dev/app run tauri",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "pnpm --filter @book.dev/server run test:e2e && pnpm --filter @book.dev/mcp run test:e2e",
    "test:e2e:web": "pnpm --filter @book.dev/web run test:e2e",
    "verify": "pnpm run build:libs && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:e2e",
    "chromatic": "pnpm --filter @book.dev/web run chromatic",
    "seed": "pnpm --filter @book.dev/server run seed",
    "clean": "rm -rf packages/sdk/dist packages/ui/dist packages/server/dist packages/server/assets packages/web/.next packages/app/dist packages/app/src-tauri/binaries/openbook-server-*",
    "prepare": "husky",
    "watch-app": "pnpm --filter @book.dev/app run tauri dev",
    "watch-sdk": "pnpm --filter @book.dev/sdk run dev",
    "watch-server": "pnpm --filter @book.dev/server run dev",
    "watch-ui": "pnpm --filter @book.dev/ui run dev",
    "watch-ui-css": "pnpm --filter @book.dev/ui run dev-css",
    "watch-ui-types": "pnpm --filter @book.dev/ui run dev-types",
    "watch-web": "pnpm --filter @book.dev/web run dev"
  },
  "author": "Eliot Lim",
  "license": "MIT",
  "dependencies": {
    "@book.dev/ui": "workspace:*",
    "resolve-tspaths": "^0.8.22"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.6",
    "@nx/js": "22.7.5",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "concurrently": "^10.0.0",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "husky": "^9.1.6",
    "nx": "^22.7.5",
    "rollup": "^4.22.4",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.7.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.15"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "use-resize-observer>react": "19",
        "use-resize-observer>react-dom": "19"
      }
    },
    "patchedDependencies": {
      "@chromatic-com/playwright@0.14.5": "patches/@chromatic-com__playwright@0.14.5.patch"
    }
  }
}
