{
  "name": "@bookhq/openbook",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "packages/openbook-ui",
    "packages/openbook-app",
    "packages/openbook-web"
  ],
  "scripts": {
    "build": "npm --workspace @bookhq/openbook-ui run build && npm --workspace @bookhq/openbook-app run tauri build",
    "commitlint": "commitlint --edit",
    "dev": "concurrently --kill-others \"npm:watch-openbook-app\" \"npm:watch-openbook-web\" \"npm:watch-openbook-ui\" \"npm:watch-openbook-ui-css\" \"npm:watch-openbook-ui-types\"",
    "lint": "npm --workspaces run lint",
    "lint-fix": "npm --workspaces run lint-fix",
    "tauri": "npm --workspace @bookhq/openbook-app run tauri",
    "test": "echo \"Warning: no test specified\" && exit 0",
    "prepare": "husky",
    "watch-openbook-app": "npm --workspace @bookhq/openbook-app run tauri dev",
    "watch-openbook-ui": "npm --workspace @bookhq/openbook-ui run dev",
    "watch-openbook-ui-css": "npm --workspace @bookhq/openbook-ui run dev-css",
    "watch-openbook-ui-types": "npm --workspace @bookhq/openbook-ui run dev-types",
    "watch-openbook-web": "npm --workspace @bookhq/openbook-web run dev",
    "postversion": "npm version --workspaces $(npm pkg get version | sed 's/\"//g')"
  },
  "author": "Eliot Lim",
  "license": "MIT",
  "dependencies": {
    "@bookhq/openbook-ui": "^1.0.0",
    "resolve-tspaths": "^0.8.18",
    "typescript": "^5.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/git": "^10.0.1",
    "@tauri-apps/cli": "^1.5.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "concurrently": "^8.2.2",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "husky": "^9.0.11",
    "rollup": "^4.13.2",
    "rollup-plugin-dts": "^6.1.0",
    "semantic-release": "^23.0.7",
    "tslib": "^2.6.2"
  }
}
