{
  "name": "@book.dev/server",
  "version": "1.60.0",
  "description": "OpenBook server: page store (Postgres) + HTTP API. Runs headless or embedded in the desktop app.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "bin": {
    "openbook-server": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/bin.ts --data-dir ./.dev-data --port 4319",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "test:e2e": "tsx scripts/e2e.mts",
    "seed": "tsx scripts/seed.mts",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@hono/node-server": "^2.0.4",
    "@book.dev/sdk": "workspace:*",
    "hono": "^4.12.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.1.6",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.13.0"
  }
}
