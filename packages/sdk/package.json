{
  "name": "@book.dev/sdk",
  "version": "1.61.2",
  "description": "Shared OpenBook types and HTTP client used by the server, desktop, and web.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
