{
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm --filter @book.dev/sdk run build && pnpm --filter @book.dev/ui run build && pnpm --filter @book.dev/server run build:sidecar && pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/openbook-server"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "productName": "OpenBook",
  "mainBinaryName": "OpenBook",
  "version": "../package.json",
  "identifier": "dev.book.open",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["openbook"]
      }
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "OpenBook",
        "width": 1440,
        "height": 900,
        "dragDropEnabled": false,
        "useHttpsScheme": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}