{
  "name": "@open-book/mcp",
  "version": "1.58.0",
  "description": "OpenBook MCP server: lets MCP clients (Claude Desktop, Claude Code, …) read and write an OpenBook workspace over stdio.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openbook-mcp": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js",
    "test:e2e": "tsx scripts/e2e.mts",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@open-book/sdk": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@open-book/server": "workspace:*",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3"
  }
}
